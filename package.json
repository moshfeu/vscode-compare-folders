{
  "name": "compare-folders",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "version": "0.29.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/moshfeu/vscode-compare-folders"
  },
  "keywords": [
    "compare",
    "compare folders",
    "diff",
    "diff folders"
  ],
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#ffbe6c",
    "theme": "light"
  },
  "publisher": "moshfeu",
  "author": {
    "name": "Mosh Feuchtwanger",
    "email": "moshfeu.dev@gmail.com",
    "url": "https://twitter.com/moshfeu"
  },
  "engines": {
    "vscode": "^1.71.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "icons": {
      "comparefolders-icon": {
        "description": "%ext.description.1%",
        "default": {
          "fontPath": "resources/fonts/comparefolders.woff",
          "fontCharacter": "\\e900"
        }
      }
    },
    "configuration": {
      "type": "object",
      "title": "%ext.title.2%",
      "properties": {
        "compareFolders.folderLeft": {
          "type": "string",
          "description": "%ext.description.3%",
          "default": "",
          "scope": "resource"
        },
        "compareFolders.folderRight": {
          "type": "string",
          "description": "%ext.description.4%",
          "default": "",
          "scope": "resource"
        },
        "compareFolders.compareContent": {
          "type": "boolean",
          "default": true,
          "description": "%ext.description.5%",
          "scope": "resource"
        },
        "compareFolders.ignoreLineEnding": {
          "type": "boolean",
          "default": false,
          "description": "%ext.description.6%",
          "scope": "resource"
        },
        "compareFolders.ignoreWhiteSpaces": {
          "type": "boolean",
          "default": false,
          "description": "%ext.description.7%",
          "scope": "resource"
        },
        "compareFolders.ignoreAllWhiteSpaces": {
          "type": "boolean",
          "default": false,
          "description": "%ext.description.8%",
          "scope": "resource"
        },
        "compareFolders.ignoreEmptyLines": {
          "type": "boolean",
          "default": false,
          "description": "%ext.description.9%",
          "scope": "resource"
        },
        "compareFolders.ignoreFileNameCase": {
          "type": "boolean",
          "default": true,
          "description": "%ext.description.10%",
          "scope": "resource"
        },
        "compareFolders.ignoreExtension": {
          "type": "array",
          "default": [],
          "description": "%ext.description.11%",
          "scope": "resource"
        },
        "compareFolders.includeFilter": {
          "type": "array",
          "description": "%ext.description.12%",
          "scope": "resource"
        },
        "compareFolders.excludeFilter": {
          "type": "array",
          "description": "%ext.description.13%",
          "scope": "resource"
        },
        "compareFolders.respectGitIgnore": {
          "type": "boolean",
          "description": "%ext.description.14%",
          "scope": "resource"
        },
        "compareFolders.diffViewTitle": {
          "type": "string",
          "default": "name only",
          "enum": [
            "name only",
            "compared path",
            "full path"
          ],
          "enumDescriptions": [
            "%ext.enumDescriptions.15%",
            "%ext.enumDescriptions.16%",
            "%ext.enumDescriptions.17%"
          ],
          "markdownDescription": "%ext.markdownDescription.18%",
          "scope": "window"
        },
        "compareFolders.diffLayout": {
          "type": "string",
          "default": "local <> compared",
          "enum": [
            "local <> compared",
            "compared <> local"
          ],
          "enumDescriptions": [
            "%ext.enumDescriptions.19%",
            "%ext.enumDescriptions.20%"
          ],
          "markdownDescription": "%ext.markdownDescription.21%",
          "scope": "window"
        },
        "compareFolders.defaultDiffViewMode": {
          "type": "string",
          "default": "tree",
          "enum": [
            "tree",
            "list"
          ],
          "enumDescriptions": [
            "%ext.enumDescriptions.22%",
            "%ext.enumDescriptions.23%"
          ],
          "scope": "window"
        },
        "compareFolders.showIdentical": {
          "type": "boolean",
          "default": false,
          "description": "%ext.description.24%",
          "scope": "resource"
        },
        "compareFolders.showFileCount": {
          "type": "boolean",
          "default": false,
          "description": "%ext.description.25%",
          "scope": "window"
        },
        "compareFolders.useDiffMerge": {
          "type": "boolean",
          "default": false,
          "description": "%ext.description.26%",
          "scope": "window"
        },
        "compareFolders.warnBeforeDelete": {
          "type": "boolean",
          "default": "true",
          "description": "%ext.description.27%",
          "scope": "resource"
        },
        "compareFolders.warnBeforeTake": {
          "type": "boolean",
          "default": true,
          "description": "%ext.description.28%",
          "scope": "resource"
        },
        "compareFolders.ignoreStrings": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "%ext.description.29%",
          "scope": "resource"
        },
        "compareFolders.fileParsingRules": {
          "type": "array",
          "default": [],
          "description": "%ext.description.30%",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "%ext.description.31%"
              },
              "command": {
                "type": "string",
                "description": "%ext.description.32%"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "%ext.description.33%"
              },
              "workingDirectory": {
                "type": "string",
                "description": "%ext.description.34%"
              },
              "timeout": {
                "type": "number",
                "default": 30000,
                "description": "%ext.description.35%"
              },
              "env": {
                "type": "object",
                "description": "%ext.description.36%",
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "required": [
              "pattern",
              "command",
              "args"
            ]
          },
          "scope": "resource"
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "foldersCompare.refresh",
          "when": "false"
        },
        {
          "command": "foldersCompare.chooseFoldersAndCompare",
          "when": "false"
        },
        {
          "command": "foldersCompare.compareFoldersAgainstWorkspace",
          "when": "workspaceFolderCount != 0"
        },
        {
          "command": "foldersCompare.compareSelectedFolders",
          "when": "false"
        },
        {
          "command": "foldersCompare.copyToCompared",
          "when": "false"
        },
        {
          "command": "foldersCompare.copyToMy",
          "when": "false"
        },
        {
          "command": "foldersCompare.takeMyFile",
          "when": "false"
        },
        {
          "command": "foldersCompare.dismissDifference",
          "when": "false"
        },
        {
          "command": "foldersCompare.takeComparedFile",
          "when": "false"
        },
        {
          "command": "foldersCompare.deleteFile",
          "when": "false"
        },
        {
          "command": "foldersCompare.excludeFromComparison",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "foldersCompare.viewAsList",
          "group": "navigation@1",
          "when": "view == foldersCompareAppService && foldersCompareContext.hasFolders && foldersCompare.diffViewMode == 'tree'"
        },
        {
          "command": "foldersCompare.viewAsTree",
          "group": "navigation@1",
          "when": "view == foldersCompareAppService && foldersCompareContext.hasFolders && foldersCompare.diffViewMode == 'list'"
        },
        {
          "command": "foldersCompare.refresh",
          "group": "navigation@2",
          "when": "view == foldersCompareAppService && foldersCompareContext.hasFolders"
        },
        {
          "command": "foldersCompare.swap",
          "group": "navigation@3",
          "when": "view == foldersCompareAppService && foldersCompareContext.hasFolders"
        },
        {
          "command": "foldersCompare.pickFromRecentCompares",
          "group": "navigation@4",
          "when": "view == foldersCompareAppService"
        }
      ],
      "explorer/context": [
        {
          "command": "foldersCompare.compareSelectedFolders",
          "when": "explorerResourceIsFolder && listDoubleSelection"
        }
      ],
      "view/item/context": [
        {
          "command": "foldersCompare.copyToCompared",
          "when": "view == foldersCompareAppServiceOnlyA && viewItem != root",
          "group": "inline@2"
        },
        {
          "command": "foldersCompare.copyToMy",
          "when": "view == foldersCompareAppServiceOnlyB && viewItem != root",
          "group": "inline@2"
        },
        {
          "command": "foldersCompare.deleteFile",
          "when": "(view == foldersCompareAppServiceOnlyA || view == foldersCompareAppServiceOnlyB) && viewItem != root",
          "group": "inline@3"
        },
        {
          "command": "foldersCompare.viewParsedDiff",
          "when": "view == foldersCompareAppService && viewItem == file-parsable",
          "group": "inline@1"
        },
        {
          "command": "foldersCompare.takeMyFile",
          "when": "view == foldersCompareAppService && (viewItem == file || viewItem == file-parsable)",
          "group": "inline@2"
        },
        {
          "command": "foldersCompare.takeComparedFile",
          "when": "view == foldersCompareAppService && (viewItem == file || viewItem == file-parsable)",
          "group": "inline@3"
        },
        {
          "command": "foldersCompare.dismissDifference",
          "when": "view == foldersCompareAppService && (viewItem == file || viewItem == file-parsable)",
          "group": "inline@4"
        },
        {
          "command": "foldersCompare.excludeFromComparison",
          "when": "view =~ /^foldersCompareAppService/ && (viewItem == file || viewItem == file-parsable || viewItem == folder)",
          "group": "inline@0"
        },
        {
          "command": "foldersCompare.excludeFromComparison",
          "when": "view =~ /^foldersCompareAppService/ && (viewItem == file || viewItem == file-parsable || viewItem == folder)"
        }
      ]
    },
    "commands": [
      {
        "title": "%ext.title.37%",
        "command": "foldersCompare.pickFromRecentCompares",
        "icon": "$(history)",
        "category": "%ext.category.38%"
      },
      {
        "title": "%ext.title.39%",
        "command": "foldersCompare.clearRecentCompares",
        "category": "%ext.category.40%"
      },
      {
        "title": "%ext.title.41%",
        "command": "foldersCompare.copyToCompared",
        "icon": "$(files)"
      },
      {
        "title": "%ext.title.42%",
        "command": "foldersCompare.copyToMy",
        "icon": "$(files)"
      },
      {
        "title": "%ext.title.43%",
        "command": "foldersCompare.deleteFile",
        "icon": "$(trash)"
      },
      {
        "title": "%ext.title.44%",
        "command": "foldersCompare.dismissDifference",
        "icon": "$(close)"
      },
      {
        "title": "%ext.title.45%",
        "command": "foldersCompare.excludeFromComparison",
        "icon": "$(exclude)"
      },
      {
        "title": "%ext.title.46%",
        "command": "foldersCompare.viewParsedDiff",
        "icon": "$(code)",
        "category": "%ext.category.47%"
      },
      {
        "title": "%ext.title.48%",
        "command": "foldersCompare.takeMyFile",
        "icon": "$(debug-step-over)"
      },
      {
        "title": "%ext.title.49%",
        "command": "foldersCompare.takeComparedFile",
        "icon": "$(debug-step-back)"
      },
      {
        "title": "%ext.title.50%",
        "command": "foldersCompare.chooseFoldersAndCompare",
        "category": "%ext.category.51%"
      },
      {
        "title": "%ext.title.52%",
        "command": "foldersCompare.compareFoldersAgainstWorkspace",
        "category": "%ext.category.53%"
      },
      {
        "title": "%ext.title.54%",
        "command": "foldersCompare.compareFoldersAgainstEachOther",
        "category": "%ext.category.55%"
      },
      {
        "title": "%ext.title.56%",
        "command": "foldersCompare.refresh",
        "icon": "$(refresh)",
        "category": "%ext.category.57%"
      },
      {
        "title": "%ext.title.58%",
        "command": "foldersCompare.swap",
        "icon": "$(arrow-swap)",
        "category": "%ext.category.59%"
      },
      {
        "title": "%ext.title.60%",
        "command": "foldersCompare.viewAsList",
        "icon": "$(list-selection)",
        "category": "%ext.category.61%"
      },
      {
        "title": "%ext.title.62%",
        "command": "foldersCompare.viewAsTree",
        "icon": "$(list-tree)",
        "category": "%ext.category.63%"
      },
      {
        "command": "foldersCompare.compareSelectedFolders",
        "title": "%ext.title.64%",
        "category": "%ext.category.65%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "foldersCompare",
          "title": "%ext.title.66%",
          "icon": "$(comparefolders-icon)"
        }
      ]
    },
    "views": {
      "foldersCompare": [
        {
          "id": "foldersCompareAppService",
          "name": "%ext.name.67%"
        },
        {
          "id": "foldersCompareAppServiceOnlyA",
          "name": "%ext.name.68%"
        },
        {
          "id": "foldersCompareAppServiceOnlyB",
          "name": "%ext.name.69%"
        },
        {
          "id": "foldersCompareAppServiceIdenticals",
          "name": "%ext.name.70%",
          "when": "config.compareFolders.showIdentical"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "yarn run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "yarn run compile",
    "test": "node ./out/test/runTest.js",
    "deploy": "npx vsce publish -p",
    "deploy:insider": "node scripts/deploy-insider.js",
    "deploy:openvsx": "sh scripts/deploy-openvsx.sh",
    "package": "npx vsce package",
    "package:test": "sh scripts/package-test.sh"
  },
  "devDependencies": {
    "@types/fs-extra": "8.1.0",
    "@types/glob": "^8.1.0",
    "@types/lodash": "^4.14.140",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.0.0",
    "@types/sinon": "^10.0.13",
    "@types/vscode": "^1.38.0",
    "@vscode/test-electron": "^2.3.8",
    "dotenv": "^8.2.0",
    "glob": "^7.1.4",
    "mocha": "^10.2.0",
    "sinon": "^14.0.0",
    "tslint": "^5.12.1",
    "typescript": "^4.7.4"
  },
  "dependencies": {
    "@cjs-exporter/globby": "^13.1.3",
    "@vscode/l10n": "^0.0.18",
    "dir-compare": "^4.2.0",
    "fs-extra": "8.1.0",
    "lodash": "^4.18.1",
    "parse-gitignore": "^2.0.0"
  }
}
