{
  "name": "compare-folders",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "version": "0.30.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/moshfeu/vscode-compare-folders"
  },
  "keywords": [
    "compare",
    "compare folders",
    "diff",
    "diff folders"
  ],
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#ffbe6c",
    "theme": "light"
  },
  "publisher": "moshfeu",
  "author": {
    "name": "Mosh Feuchtwanger",
    "email": "moshfeu.dev@gmail.com",
    "url": "https://twitter.com/moshfeu"
  },
  "engines": {
    "vscode": "^1.73.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "icons": {
      "comparefolders-icon": {
        "description": "%ext.icon.description%",
        "default": {
          "fontPath": "resources/fonts/comparefolders.woff",
          "fontCharacter": "\\e900"
        }
      }
    },
    "configuration": {
      "type": "object",
      "title": "%ext.configuration.title%",
      "properties": {
        "compareFolders.folderLeft": {
          "type": "string",
          "description": "%ext.config.folderLeft.description%",
          "default": "",
          "scope": "resource"
        },
        "compareFolders.folderRight": {
          "type": "string",
          "description": "%ext.config.folderRight.description%",
          "default": "",
          "scope": "resource"
        },
        "compareFolders.compareContent": {
          "type": "boolean",
          "default": true,
          "description": "%ext.config.compareContent.description%",
          "scope": "resource"
        },
        "compareFolders.ignoreLineEnding": {
          "type": "boolean",
          "default": false,
          "description": "%ext.config.ignoreLineEnding.description%",
          "scope": "resource"
        },
        "compareFolders.ignoreWhiteSpaces": {
          "type": "boolean",
          "default": false,
          "description": "%ext.config.ignoreWhiteSpaces.description%",
          "scope": "resource"
        },
        "compareFolders.ignoreAllWhiteSpaces": {
          "type": "boolean",
          "default": false,
          "description": "%ext.config.ignoreAllWhiteSpaces.description%",
          "scope": "resource"
        },
        "compareFolders.ignoreEmptyLines": {
          "type": "boolean",
          "default": false,
          "description": "%ext.config.ignoreEmptyLines.description%",
          "scope": "resource"
        },
        "compareFolders.ignoreFileNameCase": {
          "type": "boolean",
          "default": true,
          "description": "%ext.config.ignoreFileNameCase.description%",
          "scope": "resource"
        },
        "compareFolders.ignoreExtension": {
          "type": "array",
          "default": [],
          "description": "%ext.config.ignoreExtension.description%",
          "scope": "resource"
        },
        "compareFolders.includeFilter": {
          "type": "array",
          "description": "%ext.config.includeFilter.description%",
          "scope": "resource"
        },
        "compareFolders.excludeFilter": {
          "type": "array",
          "description": "%ext.config.excludeFilter.description%",
          "scope": "resource"
        },
        "compareFolders.respectGitIgnore": {
          "type": "boolean",
          "description": "%ext.config.respectGitIgnore.description%",
          "scope": "resource"
        },
        "compareFolders.diffViewTitle": {
          "type": "string",
          "default": "name only",
          "enum": [
            "name only",
            "compared path",
            "full path"
          ],
          "enumDescriptions": [
            "%ext.config.diffViewTitle.enum.nameOnly%",
            "%ext.config.diffViewTitle.enum.comparedPath%",
            "%ext.config.diffViewTitle.enum.fullPath%"
          ],
          "markdownDescription": "%ext.config.diffViewTitle.description%",
          "scope": "window"
        },
        "compareFolders.diffLayout": {
          "type": "string",
          "default": "local <> compared",
          "enum": [
            "local <> compared",
            "compared <> local"
          ],
          "enumDescriptions": [
            "%ext.config.diffLayout.enum.localCompared%",
            "%ext.config.diffLayout.enum.comparedLocal%"
          ],
          "markdownDescription": "%ext.config.diffLayout.description%",
          "scope": "window"
        },
        "compareFolders.defaultDiffViewMode": {
          "type": "string",
          "default": "tree",
          "enum": [
            "tree",
            "list"
          ],
          "enumDescriptions": [
            "%ext.config.defaultDiffViewMode.enum.tree%",
            "%ext.config.defaultDiffViewMode.enum.list%"
          ],
          "scope": "window"
        },
        "compareFolders.showIdentical": {
          "type": "boolean",
          "default": false,
          "description": "%ext.config.showIdentical.description%",
          "scope": "resource"
        },
        "compareFolders.showFileCount": {
          "type": "boolean",
          "default": false,
          "description": "%ext.config.showFileCount.description%",
          "scope": "window"
        },
        "compareFolders.useDiffMerge": {
          "type": "boolean",
          "default": false,
          "description": "%ext.config.useDiffMerge.description%",
          "scope": "window"
        },
        "compareFolders.warnBeforeDelete": {
          "type": "boolean",
          "default": "true",
          "description": "%ext.config.warnBeforeDelete.description%",
          "scope": "resource"
        },
        "compareFolders.warnBeforeTake": {
          "type": "boolean",
          "default": true,
          "description": "%ext.config.warnBeforeTake.description%",
          "scope": "resource"
        },
        "compareFolders.ignoreStrings": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "%ext.config.ignoreStrings.description%",
          "scope": "resource"
        },
        "compareFolders.fileParsingRules": {
          "type": "array",
          "default": [],
          "description": "%ext.config.fileParsingRules.description%",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "%ext.config.fileParsingRules.pattern.description%"
              },
              "command": {
                "type": "string",
                "description": "%ext.config.fileParsingRules.command.description%"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "%ext.config.fileParsingRules.args.description%"
              },
              "workingDirectory": {
                "type": "string",
                "description": "%ext.config.fileParsingRules.workingDirectory.description%"
              },
              "timeout": {
                "type": "number",
                "default": 30000,
                "description": "%ext.config.fileParsingRules.timeout.description%"
              },
              "env": {
                "type": "object",
                "description": "%ext.config.fileParsingRules.env.description%",
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "required": [
              "pattern",
              "command",
              "args"
            ]
          },
          "scope": "resource"
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "foldersCompare.refresh",
          "when": "false"
        },
        {
          "command": "foldersCompare.chooseFoldersAndCompare",
          "when": "false"
        },
        {
          "command": "foldersCompare.compareFoldersAgainstWorkspace",
          "when": "workspaceFolderCount != 0"
        },
        {
          "command": "foldersCompare.compareSelectedFolders",
          "when": "false"
        },
        {
          "command": "foldersCompare.copyToCompared",
          "when": "false"
        },
        {
          "command": "foldersCompare.copyToMy",
          "when": "false"
        },
        {
          "command": "foldersCompare.takeMyFile",
          "when": "false"
        },
        {
          "command": "foldersCompare.dismissDifference",
          "when": "false"
        },
        {
          "command": "foldersCompare.takeComparedFile",
          "when": "false"
        },
        {
          "command": "foldersCompare.deleteFile",
          "when": "false"
        },
        {
          "command": "foldersCompare.excludeFromComparison",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "foldersCompare.viewAsList",
          "group": "navigation@1",
          "when": "view == foldersCompareAppService && foldersCompareContext.hasFolders && foldersCompare.diffViewMode == 'tree'"
        },
        {
          "command": "foldersCompare.viewAsTree",
          "group": "navigation@1",
          "when": "view == foldersCompareAppService && foldersCompareContext.hasFolders && foldersCompare.diffViewMode == 'list'"
        },
        {
          "command": "foldersCompare.refresh",
          "group": "navigation@2",
          "when": "view == foldersCompareAppService && foldersCompareContext.hasFolders"
        },
        {
          "command": "foldersCompare.swap",
          "group": "navigation@3",
          "when": "view == foldersCompareAppService && foldersCompareContext.hasFolders"
        },
        {
          "command": "foldersCompare.pickFromRecentCompares",
          "group": "navigation@4",
          "when": "view == foldersCompareAppService"
        }
      ],
      "explorer/context": [
        {
          "command": "foldersCompare.compareSelectedFolders",
          "when": "explorerResourceIsFolder && listDoubleSelection"
        }
      ],
      "view/item/context": [
        {
          "command": "foldersCompare.copyToCompared",
          "when": "view == foldersCompareAppServiceOnlyA && viewItem != root",
          "group": "inline@2"
        },
        {
          "command": "foldersCompare.copyToMy",
          "when": "view == foldersCompareAppServiceOnlyB && viewItem != root",
          "group": "inline@2"
        },
        {
          "command": "foldersCompare.deleteFile",
          "when": "(view == foldersCompareAppServiceOnlyA || view == foldersCompareAppServiceOnlyB) && viewItem != root",
          "group": "inline@3"
        },
        {
          "command": "foldersCompare.viewParsedDiff",
          "when": "view == foldersCompareAppService && viewItem == file-parsable",
          "group": "inline@1"
        },
        {
          "command": "foldersCompare.takeMyFile",
          "when": "view == foldersCompareAppService && (viewItem == file || viewItem == file-parsable)",
          "group": "inline@2"
        },
        {
          "command": "foldersCompare.takeComparedFile",
          "when": "view == foldersCompareAppService && (viewItem == file || viewItem == file-parsable)",
          "group": "inline@3"
        },
        {
          "command": "foldersCompare.dismissDifference",
          "when": "view == foldersCompareAppService && (viewItem == file || viewItem == file-parsable)",
          "group": "inline@4"
        },
        {
          "command": "foldersCompare.excludeFromComparison",
          "when": "view =~ /^foldersCompareAppService/ && (viewItem == file || viewItem == file-parsable || viewItem == folder)",
          "group": "inline@0"
        },
        {
          "command": "foldersCompare.excludeFromComparison",
          "when": "view =~ /^foldersCompareAppService/ && (viewItem == file || viewItem == file-parsable || viewItem == folder)"
        }
      ]
    },
    "commands": [
      {
        "title": "%ext.command.pickFromRecent.title%",
        "command": "foldersCompare.pickFromRecentCompares",
        "icon": "$(history)",
        "category": "%ext.command.category%"
      },
      {
        "title": "%ext.command.clearRecent.title%",
        "command": "foldersCompare.clearRecentCompares",
        "category": "%ext.command.category%"
      },
      {
        "title": "%ext.command.copyToCompared.title%",
        "command": "foldersCompare.copyToCompared",
        "icon": "$(files)"
      },
      {
        "title": "%ext.command.copyToMy.title%",
        "command": "foldersCompare.copyToMy",
        "icon": "$(files)"
      },
      {
        "title": "%ext.command.deleteFile.title%",
        "command": "foldersCompare.deleteFile",
        "icon": "$(trash)"
      },
      {
        "title": "%ext.command.dismissDifference.title%",
        "command": "foldersCompare.dismissDifference",
        "icon": "$(close)"
      },
      {
        "title": "%ext.command.excludeFromComparison.title%",
        "command": "foldersCompare.excludeFromComparison",
        "icon": "$(exclude)"
      },
      {
        "title": "%ext.command.viewParsedDiff.title%",
        "command": "foldersCompare.viewParsedDiff",
        "icon": "$(code)",
        "category": "%ext.command.category%"
      },
      {
        "title": "%ext.command.takeMyFile.title%",
        "command": "foldersCompare.takeMyFile",
        "icon": "$(debug-step-over)"
      },
      {
        "title": "%ext.command.takeComparedFile.title%",
        "command": "foldersCompare.takeComparedFile",
        "icon": "$(debug-step-back)"
      },
      {
        "title": "%ext.command.chooseFolders.title%",
        "command": "foldersCompare.chooseFoldersAndCompare",
        "category": "%ext.command.category%"
      },
      {
        "title": "%ext.command.compareAgainstWorkspace.title%",
        "command": "foldersCompare.compareFoldersAgainstWorkspace",
        "category": "%ext.command.category%"
      },
      {
        "title": "%ext.command.choose2Folders.title%",
        "command": "foldersCompare.compareFoldersAgainstEachOther",
        "category": "%ext.command.category%"
      },
      {
        "title": "%ext.command.refresh.title%",
        "command": "foldersCompare.refresh",
        "icon": "$(refresh)",
        "category": "%ext.command.category%"
      },
      {
        "title": "%ext.command.swapSides.title%",
        "command": "foldersCompare.swap",
        "icon": "$(arrow-swap)",
        "category": "%ext.command.category%"
      },
      {
        "title": "%ext.command.viewAsList.title%",
        "command": "foldersCompare.viewAsList",
        "icon": "$(list-selection)",
        "category": "%ext.command.category%"
      },
      {
        "title": "%ext.command.viewAsTree.title%",
        "command": "foldersCompare.viewAsTree",
        "icon": "$(list-tree)",
        "category": "%ext.command.category%"
      },
      {
        "command": "foldersCompare.compareSelectedFolders",
        "title": "%ext.command.compareSelected.title%",
        "category": "%ext.command.category%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "foldersCompare",
          "title": "%ext.viewContainer.title%",
          "icon": "$(comparefolders-icon)"
        }
      ]
    },
    "views": {
      "foldersCompare": [
        {
          "id": "foldersCompareAppService",
          "name": "%ext.view.differences.name%"
        },
        {
          "id": "foldersCompareAppServiceOnlyA",
          "name": "%ext.view.onlyInMy.name%"
        },
        {
          "id": "foldersCompareAppServiceOnlyB",
          "name": "%ext.view.onlyInCompared.name%"
        },
        {
          "id": "foldersCompareAppServiceIdenticals",
          "name": "%ext.view.identicals.name%",
          "when": "config.compareFolders.showIdentical"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "yarn run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "yarn run compile",
    "test": "node ./out/test/runTest.js",
    "l10n:extract": "npx @vscode/l10n-dev export --outDir ./l10n ./src/**/*.ts",
    "l10n:validate": "node scripts/validate-l10n.js",
    "deploy": "npx vsce publish -p",
    "deploy:insider": "node scripts/deploy-insider.js",
    "deploy:openvsx": "sh scripts/deploy-openvsx.sh",
    "package": "npx vsce package",
    "package:test": "sh scripts/package-test.sh"
  },
  "devDependencies": {
    "@types/fs-extra": "8.1.0",
    "@types/glob": "^8.1.0",
    "@types/lodash": "^4.14.140",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.0.0",
    "@types/sinon": "^10.0.13",
    "@types/vscode": "^1.110.0",
    "@vscode/l10n-dev": "^0.0.35",
    "@vscode/test-electron": "^2.3.8",
    "dotenv": "^8.2.0",
    "glob": "^7.1.4",
    "mocha": "^10.2.0",
    "sinon": "^14.0.0",
    "tslint": "^5.12.1",
    "typescript": "^4.7.4"
  },
  "dependencies": {
    "@cjs-exporter/globby": "^13.1.3",
    "@vscode/l10n": "^0.0.18",
    "dir-compare": "^4.2.0",
    "fs-extra": "8.1.0",
    "lodash": "^4.18.1",
    "parse-gitignore": "^2.0.0"
  }
}
